{
  "name": "slidev-theme-ldr",
  "version": "0.0.1",
  "type": "module",
  "description": "Personal Slidev theme for Lars De Richter.",
  "author": "Lars De Richter",
  "license": "Unlicense",
  "keywords": [
    "slidev-theme",
    "slidev",
    "theme"
  ],
  "engines": {
    "slidev": ">=52.0.0"
  },
  "slidev": {
    "themeName": "ldr",
    "defaults": {
      "aspectRatio": "16/9"
    }
  },
  "scripts": {
    "dev": "slidev example.md --open",
    "build": "slidev build example.md",
    "export": "slidev export example.md",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@slidev/cli": "^52.10.1",
    "prettier": "^3.8.3",
    "prettier-plugin-slidev": "^1.0.5",
    "vue": "^3.5.25"
  }
}
